{
  "name": "monopoly",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream run dev",
    "dev:client": "pnpm --filter @monopoly/client dev",
    "dev:server": "pnpm --filter @monopoly/server dev",
    "build": "tsc -b && pnpm -r run build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
